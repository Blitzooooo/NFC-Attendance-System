   1:BSP/NFC.c     **** /**
   2:BSP/NFC.c     ****  * @file    NFC.c
   3:BSP/NFC.c     ****  * @brief   NFC 卡读写封装模块实现
   4:BSP/NFC.c     ****  * @details 封装了以下流程:
   5:BSP/NFC.c     ****  *          1. 密钥验证 + 读 Block1 (带重试)
   6:BSP/NFC.c     ****  *          2. 校验和验证
   7:BSP/NFC.c     ****  *          3. 卡数据字段解析
   8:BSP/NFC.c     ****  *          4. 卡类型分类 (普通/图像/管理员)
   9:BSP/NFC.c     ****  *          5. 姓名/部门/头像位图读取
  10:BSP/NFC.c     ****  */
  11:BSP/NFC.c     **** 
  12:BSP/NFC.c     **** #include "NFC.h"
  13:BSP/NFC.c     **** #include "rc522.h"
  14:BSP/NFC.c     **** #include "uart_drv.h"
  15:BSP/NFC.c     **** #include "delay_us.h"
  16:BSP/NFC.c     **** #include "record.h"
  17:BSP/NFC.c     **** #include <string.h>
  18:BSP/NFC.c     **** #include <stdio.h>
  19:BSP/NFC.c     **** #include <stdlib.h>
  20:BSP/NFC.c     **** 
  21:BSP/NFC.c     **** /* ====== 内部常量 ====== */
  22:BSP/NFC.c     **** 
  23:BSP/NFC.c     **** /** 读卡重试次数 */
  24:BSP/NFC.c     **** #define NFC_READ_RETRY      3
  25:BSP/NFC.c     **** 
  26:BSP/NFC.c     **** /** Mifare 默认密钥 (出厂值) */
  27:BSP/NFC.c     **** static const uint8_t s_defaultKey[6] = {0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF};
  28:BSP/NFC.c     **** 
  29:BSP/NFC.c     **** /** 单扇区数据块数 (不含密钥块) */
  30:BSP/NFC.c     **** #define NFC_BLOCKS_PER_SEC  3
ARM GAS  C:\Users\24120\AppData\Local\Temp\ccaaYZuv.s 			page 2


  31:BSP/NFC.c     **** 
  32:BSP/NFC.c     **** /** Block 数据长度 */
  33:BSP/NFC.c     **** #define NFC_BLOCK_SIZE      16
  34:BSP/NFC.c     **** 
  35:BSP/NFC.c     **** /* ====== 内部辅助宏: 读一个扇区的非密钥块到缓冲区 ====== */
  36:BSP/NFC.c     **** 
  37:BSP/NFC.c     **** /**
  38:BSP/NFC.c     ****  * @brief  读取指定扇区中前 3 个数据块到目标缓冲区
  39:BSP/NFC.c     ****  * @param  sec    扇区号 (0~15)
  40:BSP/NFC.c     ****  * @param  dst    目标缓冲区指针
  41:BSP/NFC.c     ****  * @param  offset 写入偏移 (字节)
  42:BSP/NFC.c     ****  * @note   自动处理密钥验证, 验证失败时静默跳过该扇区
  43:BSP/NFC.c     ****  */
  44:BSP/NFC.c     **** #define NFC_READ_SECTOR(sec, dst, offset) do {                                        \
  45:BSP/NFC.c     ****     char _st;                                                                         \
  46:BSP/NFC.c     ****     _st = RC522_AuthState(RC522_PICC_AUTHENT1A,                                       \
  47:BSP/NFC.c     ****                           (uint8_t)((sec) * 4 + 3), s_defaultKey, outCard->uid);      \
  48:BSP/NFC.c     ****     if (_st == RC522_OK) {                                                            \
  49:BSP/NFC.c     ****         for (int _b = 0; _b < NFC_BLOCKS_PER_SEC; _b++) {                             \
  50:BSP/NFC.c     ****             RC522_ReadBlock((sec), (uint8_t)_b,                                       \
  51:BSP/NFC.c     ****                             (dst) + (offset) + _b * NFC_BLOCK_SIZE);                  \
  52:BSP/NFC.c     ****         }                                                                             \
  53:BSP/NFC.c     ****     }                                                                                 \
  54:BSP/NFC.c     ****     osDelay(2);  /* 任务切换延时, 让出 CPU 给 guiTask 刷新 OLED */            \
  55:BSP/NFC.c     **** } while(0)
  56:BSP/NFC.c     **** 
  57:BSP/NFC.c     **** 
  58:BSP/NFC.c     **** /* ====== 公开 API ====== */
  59:BSP/NFC.c     **** 
  60:BSP/NFC.c     **** /**
  61:BSP/NFC.c     ****  * @brief  初始化 NFC 模块
  62:BSP/NFC.c     ****  */
  63:BSP/NFC.c     **** void NFC_Init(void)
  64:BSP/NFC.c     **** {
  65:BSP/NFC.c     ****     RC522_Platform_Init();
  66:BSP/NFC.c     ****     RC522_ConfigISOType('A');   /* ISO14443A, 内部自动开启天线 */
  67:BSP/NFC.c     **** }
  68:BSP/NFC.c     **** 
  69:BSP/NFC.c     **** /**
  70:BSP/NFC.c     ****  * @brief  寻卡
  71:BSP/NFC.c     ****  */
  72:BSP/NFC.c     **** char NFC_ScanCard(uint8_t uid[4])
  73:BSP/NFC.c     **** {
  74:BSP/NFC.c     ****     return RC522_ScanCard(uid);
  75:BSP/NFC.c     **** }
  76:BSP/NFC.c     **** 
  77:BSP/NFC.c     **** /**
  78:BSP/NFC.c     ****  * @brief  等待卡离开
  79:BSP/NFC.c     ****  */
  80:BSP/NFC.c     **** void NFC_WaitCardOff(void)
  81:BSP/NFC.c     **** {
  82:BSP/NFC.c     ****     RC522_WaitCardOff();
  83:BSP/NFC.c     **** }
  84:BSP/NFC.c     **** 
  85:BSP/NFC.c     **** /**
  86:BSP/NFC.c     ****  * @brief  RC522 硬件恢复: 复位芯片 + 重配置 ISO14443A + 重开天线
  87:BSP/NFC.c     ****  * @note   在 UPDATEIMG/CLEAR 等密集操作后、或读卡连续失败后调用,
ARM GAS  C:\Users\24120\AppData\Local\Temp\ccaaYZuv.s 			page 3


  88:BSP/NFC.c     ****  *         防止 RC522 内部 FIFO/状态机残留导致后续通信异常。
  89:BSP/NFC.c     ****  *         参考 NFCWriter 的 NFC_App_Recover()。
  90:BSP/NFC.c     ****  */
  91:BSP/NFC.c     **** void NFC_Recover(void)
  92:BSP/NFC.c     **** {
  93:BSP/NFC.c     ****     RC522_Reset();                 /* RST 引脚脉冲 + CMD_RESETPHASE 软复位 */
  94:BSP/NFC.c     ****     osDelay(10);
  95:BSP/NFC.c     ****     RC522_ConfigISOType('A');      /* 重配置 ISO14443A, 自动开天线 */
  96:BSP/NFC.c     **** }
  97:BSP/NFC.c     **** 
  98:BSP/NFC.c     **** /**
  99:BSP/NFC.c     ****  * @brief  读取并解析一张卡的全部数据
 100:BSP/NFC.c     ****  * @note   处理流程:
 101:BSP/NFC.c     ****  *          1. 捕捉刷卡时刻
 102:BSP/NFC.c     ****  *          2. 验证扇区0 + 读取 Block1 (含重试)
 103:BSP/NFC.c     ****  *          3. 校验和验证
 104:BSP/NFC.c     ****  *          4. 解析字段: 卡号/工号/积分/卡类型/状态
 105:BSP/NFC.c     ****  *          5. 分类 (管理员/图像/普通)
 106:BSP/NFC.c     ****  *          6. 对有效卡读取姓名/部门/头像位图
 107:BSP/NFC.c     ****  */
 108:BSP/NFC.c     **** NFC_Event_t NFC_ReadCard(const uint8_t uid[4], NFC_CardData_t *outCard)
 109:BSP/NFC.c     **** {
 110:BSP/NFC.c     ****     char    status;
 111:BSP/NFC.c     ****     uint8_t blockData[NFC_BLOCK_SIZE];
 112:BSP/NFC.c     ****     int     readOk = 0;
 113:BSP/NFC.c     **** 
 114:BSP/NFC.c     ****     if (outCard == NULL || uid == NULL) {
 115:BSP/NFC.c     ****         return NFC_EVT_INVALID;
 116:BSP/NFC.c     ****     }
 117:BSP/NFC.c     **** 
 118:BSP/NFC.c     ****     /* ---- 初始化输出结构 ---- */
 119:BSP/NFC.c     ****     memset(outCard, 0, sizeof(NFC_CardData_t));
 120:BSP/NFC.c     ****     memcpy(outCard->uid, uid, 4);
 121:BSP/NFC.c     **** 
 122:BSP/NFC.c     ****     /* 捕获刷卡时刻 */
 123:BSP/NFC.c     ****     BSP_RTC_GetDateTime(&outCard->swipeDT);
 124:BSP/NFC.c     **** 
 125:BSP/NFC.c     ****     /* ===== 第1步: 验证扇区0 + 读 Block1 (含重试) ===== */
 126:BSP/NFC.c     ****     for (int retry = 0; retry < NFC_READ_RETRY; retry++) {
 127:BSP/NFC.c     ****         if (retry > 0) {
 128:BSP/NFC.c     ****             /* 重试前先 Halt + 重新寻卡 */
 129:BSP/NFC.c     ****             RC522_Halt();
 130:BSP/NFC.c     ****             osDelay(5);
 131:BSP/NFC.c     ****             uint8_t reUID[4];
 132:BSP/NFC.c     ****             status = RC522_ScanCard(reUID);
 133:BSP/NFC.c     ****             if (status != RC522_OK) continue;
 134:BSP/NFC.c     ****         }
 135:BSP/NFC.c     **** 
 136:BSP/NFC.c     ****         /* 验证扇区0 密钥块 (块地址 0*4+3 = 3) */
 137:BSP/NFC.c     ****         status = RC522_AuthState(RC522_PICC_AUTHENT1A,
 138:BSP/NFC.c     ****                                  3, (uint8_t *)s_defaultKey, outCard->uid);
 139:BSP/NFC.c     ****         if (status != RC522_OK) continue;
 140:BSP/NFC.c     **** 
 141:BSP/NFC.c     ****         /* 读扇区0 块1 (账户头数据) */
 142:BSP/NFC.c     ****         status = RC522_ReadBlock(0, 1, blockData);
 143:BSP/NFC.c     ****         if (status == RC522_OK) {
 144:BSP/NFC.c     ****             readOk = 1;
ARM GAS  C:\Users\24120\AppData\Local\Temp\ccaaYZuv.s 			page 4


 145:BSP/NFC.c     ****             break;
 146:BSP/NFC.c     ****         }
 147:BSP/NFC.c     ****     }
 148:BSP/NFC.c     **** 
 149:BSP/NFC.c     ****     if (!readOk) {
 150:BSP/NFC.c     ****         return NFC_EVT_INVALID;
 151:BSP/NFC.c     ****     }
 152:BSP/NFC.c     **** 
 153:BSP/NFC.c     ****     /* ===== 第2步: 校验和验证 ===== */
 154:BSP/NFC.c     ****     uint16_t sum = 0;
 155:BSP/NFC.c     ****     for (int i = 0; i < 14; i++) {
 156:BSP/NFC.c     ****         sum += blockData[i];
 157:BSP/NFC.c     ****     }
 158:BSP/NFC.c     ****     uint16_t checksum = blockData[14] | ((uint16_t)blockData[15] << 8);
 159:BSP/NFC.c     **** 
 160:BSP/NFC.c     ****     outCard->statusFlag = blockData[13];
 161:BSP/NFC.c     **** 
 162:BSP/NFC.c     ****     /* 校验失败 或 挂失卡 → 无效 */
 163:BSP/NFC.c     ****     if (sum != checksum || outCard->statusFlag == 0xFF) {
 164:BSP/NFC.c     ****         return NFC_EVT_INVALID;
 165:BSP/NFC.c     ****     }
 166:BSP/NFC.c     **** 
 167:BSP/NFC.c     ****     /* ===== 第3步: 解析卡数据字段 ===== */
 168:BSP/NFC.c     ****     outCard->cardId =  (uint32_t)blockData[0]        |
 169:BSP/NFC.c     ****                       ((uint32_t)blockData[1] << 8)  |
 170:BSP/NFC.c     ****                       ((uint32_t)blockData[2] << 16) |
 171:BSP/NFC.c     ****                       ((uint32_t)blockData[3] << 24);
 172:BSP/NFC.c     **** 
 173:BSP/NFC.c     ****     outCard->sid   =  (uint32_t)blockData[4]        |
 174:BSP/NFC.c     ****                       ((uint32_t)blockData[5] << 8)  |
 175:BSP/NFC.c     ****                       ((uint32_t)blockData[6] << 16) |
 176:BSP/NFC.c     ****                       ((uint32_t)blockData[7] << 24);
 177:BSP/NFC.c     **** 
 178:BSP/NFC.c     ****     outCard->points =  (uint32_t)blockData[8]        |
 179:BSP/NFC.c     ****                       ((uint32_t)blockData[9] << 8)  |
 180:BSP/NFC.c     ****                       ((uint32_t)blockData[10] << 16) |
 181:BSP/NFC.c     ****                       ((uint32_t)blockData[11] << 24);
 182:BSP/NFC.c     **** 
 183:BSP/NFC.c     ****     outCard->cardType = blockData[12];
 184:BSP/NFC.c     **** 
 185:BSP/NFC.c     ****     /* 全零数据块视为空卡 (销卡后), 无需读取图像扇区 */
 186:BSP/NFC.c     ****     if (outCard->cardId == 0 && outCard->cardType == 0) {
 187:BSP/NFC.c     ****         return NFC_EVT_INVALID;
 188:BSP/NFC.c     ****     }
 189:BSP/NFC.c     **** 
 190:BSP/NFC.c     ****     /* ===== 第4步: 卡类型分类 ===== */
 191:BSP/NFC.c     ****     NFC_Event_t event;
 192:BSP/NFC.c     ****     switch (outCard->cardType) {
 193:BSP/NFC.c     ****     case 0x02:
 194:BSP/NFC.c     ****         event = NFC_EVT_ADMIN;
 195:BSP/NFC.c     ****         break;
 196:BSP/NFC.c     ****     case 0x01:
 197:BSP/NFC.c     ****     default:
 198:BSP/NFC.c     ****         event = NFC_EVT_VALID;
 199:BSP/NFC.c     ****         break;
 200:BSP/NFC.c     ****     }
 201:BSP/NFC.c     **** 
ARM GAS  C:\Users\24120\AppData\Local\Temp\ccaaYZuv.s 			page 5


 202:BSP/NFC.c     ****     /* ===== 第5步: 读取姓名/部门/头像位图 (管理员卡跳过, 节省 ~200ms) ===== */
 203:BSP/NFC.c     ****     if (event != NFC_EVT_ADMIN) {
 204:BSP/NFC.c     ****         DispCardBitmap_t *bm = DISP_GetBitmapBuf();
 205:BSP/NFC.c     ****         memset(bm, 0, sizeof(DispCardBitmap_t));
 206:BSP/NFC.c     **** 
 207:BSP/NFC.c     ****         /* -- 姓名: 10 块 = 160 字节 (扇区 9~11 全 3 块 + 扇区 12 块 0) -- */
 208:BSP/NFC.c     ****         NFC_READ_SECTOR(9,  bm->name, 0);
 209:BSP/NFC.c     ****         NFC_READ_SECTOR(10, bm->name, 48);
 210:BSP/NFC.c     ****         NFC_READ_SECTOR(11, bm->name, 96);
 211:BSP/NFC.c     ****         {
 212:BSP/NFC.c     ****             char _st = RC522_AuthState(RC522_PICC_AUTHENT1A,
 213:BSP/NFC.c     ****                                        (uint8_t)(12 * 4 + 3),
 214:BSP/NFC.c     ****                                        s_defaultKey, outCard->uid);
 215:BSP/NFC.c     ****             if (_st == RC522_OK) {
 216:BSP/NFC.c     ****                 RC522_ReadBlock(12, 0, bm->name + 144);
 217:BSP/NFC.c     ****             }
 218:BSP/NFC.c     ****         }
 219:BSP/NFC.c     ****         osDelay(2);
 220:BSP/NFC.c     **** 
 221:BSP/NFC.c     ****         /* -- 部门: 10 块 = 160 字节 (扇区 12 块 1~2 + 扇区 13~14 全 + 扇区 15 块 0~1) -- */
 222:BSP/NFC.c     ****         {
 223:BSP/NFC.c     ****             char _st = RC522_AuthState(RC522_PICC_AUTHENT1A,
 224:BSP/NFC.c     ****                                        (uint8_t)(12 * 4 + 3),
 225:BSP/NFC.c     ****                                        s_defaultKey, outCard->uid);
 226:BSP/NFC.c     ****             if (_st == RC522_OK) {
 227:BSP/NFC.c     ****                 RC522_ReadBlock(12, 1, bm->dept + 0);
 228:BSP/NFC.c     ****                 RC522_ReadBlock(12, 2, bm->dept + 16);
 229:BSP/NFC.c     ****             }
 230:BSP/NFC.c     ****         }
 231:BSP/NFC.c     ****         osDelay(2);
 232:BSP/NFC.c     ****         NFC_READ_SECTOR(13, bm->dept, 32);
 233:BSP/NFC.c     ****         NFC_READ_SECTOR(14, bm->dept, 80);
 234:BSP/NFC.c     ****         {
 235:BSP/NFC.c     ****             char _st = RC522_AuthState(RC522_PICC_AUTHENT1A,
 236:BSP/NFC.c     ****                                        (uint8_t)(15 * 4 + 3),
 237:BSP/NFC.c     ****                                        s_defaultKey, outCard->uid);
 238:BSP/NFC.c     ****             if (_st == RC522_OK) {
 239:BSP/NFC.c     ****                 RC522_ReadBlock(15, 0, bm->dept + 128);
 240:BSP/NFC.c     ****                 RC522_ReadBlock(15, 1, bm->dept + 144);
 241:BSP/NFC.c     ****             }
 242:BSP/NFC.c     ****         }
 243:BSP/NFC.c     ****         osDelay(2);
 244:BSP/NFC.c     **** 
 245:BSP/NFC.c     ****         /* -- 头像: 仅图像卡 (扇区 1~8, 共 24 块 = 384 字节位图) -- */
 246:BSP/NFC.c     ****         if (outCard->cardType == 0x01) {
 247:BSP/NFC.c     ****             NFC_READ_SECTOR(1, bm->avatar, 0);
 248:BSP/NFC.c     ****             NFC_READ_SECTOR(2, bm->avatar, 48);
 249:BSP/NFC.c     ****             NFC_READ_SECTOR(3, bm->avatar, 96);
 250:BSP/NFC.c     ****             NFC_READ_SECTOR(4, bm->avatar, 144);
 251:BSP/NFC.c     ****             NFC_READ_SECTOR(5, bm->avatar, 192);
 252:BSP/NFC.c     ****             NFC_READ_SECTOR(6, bm->avatar, 240);
 253:BSP/NFC.c     ****             NFC_READ_SECTOR(7, bm->avatar, 288);
 254:BSP/NFC.c     ****             NFC_READ_SECTOR(8, bm->avatar, 336);
 255:BSP/NFC.c     ****             /* 扫描全部 384 字节判断头像是否存在 (仅 32 字节易因黑边上角误判) */
 256:BSP/NFC.c     ****             bm->hasAvatar = 0;
 257:BSP/NFC.c     ****             for (int _j = 0; _j < (int)sizeof(bm->avatar); _j++) {
 258:BSP/NFC.c     ****                 if (bm->avatar[_j] != 0) { bm->hasAvatar = 1; break; }
ARM GAS  C:\Users\24120\AppData\Local\Temp\ccaaYZuv.s 			page 6


 259:BSP/NFC.c     ****             }
 260:BSP/NFC.c     ****         }
 261:BSP/NFC.c     ****     }
 262:BSP/NFC.c     **** 
 263:BSP/NFC.c     ****     return event;
 264:BSP/NFC.c     **** }
 265:BSP/NFC.c     **** 
 266:BSP/NFC.c     **** /**
 267:BSP/NFC.c     ****  * @brief  轻量读卡: 仅读 Block1 账户头, 不读图像扇区
 268:BSP/NFC.c     ****  * @note   用于 CmdDone 快速重读 (printf 上报仅需账户头字段),
 269:BSP/NFC.c     ****  *         大幅缩短持锁时间 (约 10ms vs 全量读的 ~1s)。
 270:BSP/NFC.c     ****  *         不调用 DISP_GetBitmapBuf(), 不修改 s_cardBitmap。
 271:BSP/NFC.c     ****  */
 272:BSP/NFC.c     **** NFC_Event_t NFC_ReadCardHeader(const uint8_t uid[4], NFC_CardData_t *outCard)
 273:BSP/NFC.c     **** {
 274:BSP/NFC.c     ****     char    status;
 275:BSP/NFC.c     ****     uint8_t blockData[NFC_BLOCK_SIZE];
 276:BSP/NFC.c     ****     int     readOk = 0;
 277:BSP/NFC.c     **** 
 278:BSP/NFC.c     ****     if (outCard == NULL || uid == NULL) {
 279:BSP/NFC.c     ****         return NFC_EVT_INVALID;
 280:BSP/NFC.c     ****     }
 281:BSP/NFC.c     **** 
 282:BSP/NFC.c     ****     memset(outCard, 0, sizeof(NFC_CardData_t));
 283:BSP/NFC.c     ****     memcpy(outCard->uid, uid, 4);
 284:BSP/NFC.c     ****     BSP_RTC_GetDateTime(&outCard->swipeDT);
 285:BSP/NFC.c     **** 
 286:BSP/NFC.c     ****     /* 读扇区0 Block1 (含重试) */
 287:BSP/NFC.c     ****     for (int retry = 0; retry < NFC_READ_RETRY; retry++) {
 288:BSP/NFC.c     ****         if (retry > 0) {
 289:BSP/NFC.c     ****             RC522_Halt();
 290:BSP/NFC.c     ****             osDelay(5);
 291:BSP/NFC.c     ****             uint8_t reUID[4];
 292:BSP/NFC.c     ****             status = RC522_ScanCard(reUID);
 293:BSP/NFC.c     ****             if (status != RC522_OK) continue;
 294:BSP/NFC.c     ****         }
 295:BSP/NFC.c     ****         status = RC522_AuthState(RC522_PICC_AUTHENT1A,
 296:BSP/NFC.c     ****                                  3, (uint8_t *)s_defaultKey, outCard->uid);
