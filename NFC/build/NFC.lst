 539:BSP/NFC.c     **** 
 540:BSP/NFC.c     **** /**
 541:BSP/NFC.c     ****  * @brief  UPDATEIMG: 将缓存的图像块写入卡片
 542:BSP/NFC.c     ****  *         头像: 扇区1~8 (1*4+3=7 ~ 8*4+3=35)
 543:BSP/NFC.c     ****  *         姓名: 扇区9~12块0
 544:BSP/NFC.c     ****  *         部门: 扇区12块1~15块1
 545:BSP/NFC.c     ****  */
 546:BSP/NFC.c     **** static const char *NFC_CmdUpdateImg(void)
 547:BSP/NFC.c     **** {
 548:BSP/NFC.c     ****     uint8_t uid[4];
 549:BSP/NFC.c     ****     char    status;
 550:BSP/NFC.c     ****     int     i, sec, blk;
 551:BSP/NFC.c     **** 
 552:BSP/NFC.c     ****     RC522_Halt();
 553:BSP/NFC.c     ****     osDelay(2);
 554:BSP/NFC.c     ****     status = RC522_ScanCard(uid);
 555:BSP/NFC.c     ****     if (status != RC522_OK) return "ERR:NOCARD\n";
 556:BSP/NFC.c     **** 
 557:BSP/NFC.c     ****     /* ---- 写头像 (扇区 1~8, 每扇区 3 块) ---- */
 558:BSP/NFC.c     ****     for (i = 0; i < NFC_IMG_AVATAR_BLOCKS; i++) {
 559:BSP/NFC.c     ****         sec = 1 + i / 3;
 560:BSP/NFC.c     ****         blk = i % 3;
 561:BSP/NFC.c     ****         status = RC522_AuthState(RC522_PICC_AUTHENT1A,
 562:BSP/NFC.c     ****                                  (uint8_t)(sec * 4 + 3),
 563:BSP/NFC.c     ****                                  (uint8_t*)s_defaultKey, uid);
 564:BSP/NFC.c     ****         if (status != RC522_OK) { NFC_Recover(); return "ERR:AUTH\n"; }
 565:BSP/NFC.c     ****         status = RC522_WriteBlock(sec, blk, s_imgAvatar[i]);
 566:BSP/NFC.c     ****         if (status != RC522_OK) { NFC_Recover(); return "ERR:WRITE_B1\n"; }
 567:BSP/NFC.c     ****         osDelay(10);  /* 等待卡 EEPROM 写入完成, 同时让出 CPU 给 guiTask 刷新 OLED */
 568:BSP/NFC.c     ****     }
 569:BSP/NFC.c     **** 
 570:BSP/NFC.c     ****     /* ---- 写姓名 (扇区 9~11 全 + 扇区12 块0) ---- */
 571:BSP/NFC.c     ****     for (i = 0; i < NFC_IMG_NAME_BLOCKS; i++) {
 572:BSP/NFC.c     ****         sec = 9 + i / 3;
 573:BSP/NFC.c     ****         blk = i % 3;
 574:BSP/NFC.c     ****         status = RC522_AuthState(RC522_PICC_AUTHENT1A,
ARM GAS  C:\Users\24120\AppData\Local\Temp\ccaaYZuv.s 			page 88


 575:BSP/NFC.c     ****                                  (uint8_t)(sec * 4 + 3),
 576:BSP/NFC.c     ****                                  (uint8_t*)s_defaultKey, uid);
 577:BSP/NFC.c     ****         if (status != RC522_OK) { NFC_Recover(); return "ERR:AUTH\n"; }
 578:BSP/NFC.c     ****         status = RC522_WriteBlock(sec, blk, s_imgName[i]);
 579:BSP/NFC.c     ****         if (status != RC522_OK) { NFC_Recover(); return "ERR:WRITE_B1\n"; }
 580:BSP/NFC.c     ****         osDelay(10);
 581:BSP/NFC.c     ****     }
 582:BSP/NFC.c     **** 
 583:BSP/NFC.c     ****     /* ---- 写部门 (扇区 12 块1~2 + 扇区 13~14 全 + 扇区 15 块0~1) ---- */
 584:BSP/NFC.c     ****     for (i = 0; i < NFC_IMG_DEPT_BLOCKS; i++) {
 585:BSP/NFC.c     ****         if (i < 2) { sec = 12; blk = 1 + i; }           /* 扇区12 块1,2 */
 586:BSP/NFC.c     ****         else if (i < 5) { sec = 13; blk = i - 2; }       /* 扇区13 块0,1,2 */
 587:BSP/NFC.c     ****         else if (i < 8) { sec = 14; blk = i - 5; }       /* 扇区14 块0,1,2 */
 588:BSP/NFC.c     ****         else             { sec = 15; blk = i - 8; }       /* 扇区15 块0,1 */
 589:BSP/NFC.c     ****         status = RC522_AuthState(RC522_PICC_AUTHENT1A,
 590:BSP/NFC.c     ****                                  (uint8_t)(sec * 4 + 3),
 591:BSP/NFC.c     ****                                  (uint8_t*)s_defaultKey, uid);
 592:BSP/NFC.c     ****         if (status != RC522_OK) { NFC_Recover(); return "ERR:AUTH\n"; }
 593:BSP/NFC.c     ****         status = RC522_WriteBlock(sec, blk, s_imgDept[i]);
 594:BSP/NFC.c     ****         if (status != RC522_OK) { NFC_Recover(); return "ERR:WRITE_B1\n"; }
 595:BSP/NFC.c     ****         osDelay(10);
 596:BSP/NFC.c     ****     }
 597:BSP/NFC.c     **** 
 598:BSP/NFC.c     ****     /* 写完后 Halt 卡 + 硬件恢复 RC522 (密集写入可能腐败芯片状态) */
 599:BSP/NFC.c     ****     RC522_Halt();
 600:BSP/NFC.c     ****     osDelay(5);
 601:BSP/NFC.c     ****     NFC_Recover();
 602:BSP/NFC.c     ****     NFC_ClearImageCache();  /* 释放 704 字节静态缓存 */
 603:BSP/NFC.c     **** 
 604:BSP/NFC.c     ****     /* 通知 nfcTask 全量重读以刷新 OLED 位图 */
 605:BSP/NFC.c     ****     NFC_SetFullReread();
 606:BSP/NFC.c     **** 
 607:BSP/NFC.c     ****     return "OK\n";
 608:BSP/NFC.c     **** }
 609:BSP/NFC.c     **** 
 610:BSP/NFC.c     **** /* ====== 公开 API ====== */
 611:BSP/NFC.c     **** 
