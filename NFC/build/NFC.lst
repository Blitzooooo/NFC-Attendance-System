 422:BSP/NFC.c     **** /* ====== 命令处理 ====== */
 423:BSP/NFC.c     **** 
 424:BSP/NFC.c     **** /**
 425:BSP/NFC.c     ****  * @brief  写账户头到卡 Block1
 426:BSP/NFC.c     ****  * @param  cardId   卡号 (4B HEX)
 427:BSP/NFC.c     ****  * @param  sid      学号/工号 (十进制, 8 位如 23041036)
 428:BSP/NFC.c     ****  * @param  points   积分
 429:BSP/NFC.c     ****  * @param  cardType 卡类型
 430:BSP/NFC.c     ****  * @return 响应字符串
 431:BSP/NFC.c     ****  */
 432:BSP/NFC.c     **** static const char *NFC_CmdIssue(const char *args)
 433:BSP/NFC.c     **** {
 434:BSP/NFC.c     ****     uint32_t cardId, sid, points;
 435:BSP/NFC.c     ****     int      cardType;
 436:BSP/NFC.c     ****     uint8_t  blockData[16];
 437:BSP/NFC.c     ****     uint8_t  uid[4];
 438:BSP/NFC.c     ****     char     status;
 439:BSP/NFC.c     **** 
 440:BSP/NFC.c     ****     if (sscanf(args, "%x,%u,%u,%d", &cardId, &sid, &points, &cardType) < 4) {
 441:BSP/NFC.c     ****         return "ERR:PARSE\n";
 442:BSP/NFC.c     ****     }
 443:BSP/NFC.c     ****     if (cardType < 0 || cardType > 2) return "ERR:PARSE\n";
 444:BSP/NFC.c     **** 
 445:BSP/NFC.c     ****     /* 寻卡 (先 Halt 复位, 避免卡留在 ACTIVE 态) */
 446:BSP/NFC.c     ****     RC522_Halt();
 447:BSP/NFC.c     ****     osDelay(2);
 448:BSP/NFC.c     ****     status = RC522_ScanCard(uid);
 449:BSP/NFC.c     ****     if (status != RC522_OK) return "ERR:NOCARD\n";
 450:BSP/NFC.c     **** 
 451:BSP/NFC.c     ****     /* 构造 Block1 数据 */
 452:BSP/NFC.c     ****     memset(blockData, 0, sizeof(blockData));
 453:BSP/NFC.c     ****     blockData[0]  = (uint8_t)(cardId);
 454:BSP/NFC.c     ****     blockData[1]  = (uint8_t)(cardId >> 8);
 455:BSP/NFC.c     ****     blockData[2]  = (uint8_t)(cardId >> 16);
 456:BSP/NFC.c     ****     blockData[3]  = (uint8_t)(cardId >> 24);
ARM GAS  C:\Users\24120\AppData\Local\Temp\ccaaYZuv.s 			page 14


 457:BSP/NFC.c     ****     blockData[4]  = (uint8_t)(sid);
 458:BSP/NFC.c     ****     blockData[5]  = (uint8_t)(sid >> 8);
 459:BSP/NFC.c     ****     blockData[6]  = (uint8_t)(sid >> 16);
 460:BSP/NFC.c     ****     blockData[7]  = (uint8_t)(sid >> 24);
 461:BSP/NFC.c     ****     blockData[8]  = (uint8_t)(points);
 462:BSP/NFC.c     ****     blockData[9]  = (uint8_t)(points >> 8);
 463:BSP/NFC.c     ****     blockData[10] = (uint8_t)(points >> 16);
 464:BSP/NFC.c     ****     blockData[11] = (uint8_t)(points >> 24);
 465:BSP/NFC.c     ****     blockData[12] = (uint8_t)cardType;
 466:BSP/NFC.c     ****     blockData[13] = 0x00;  /* statusFlag: 正常 */
 467:BSP/NFC.c     **** 
 468:BSP/NFC.c     ****     /* 校验和 (前14字节累加) */
 469:BSP/NFC.c     ****     uint16_t sum = 0;
 470:BSP/NFC.c     ****     for (int i = 0; i < 14; i++) sum += blockData[i];
 471:BSP/NFC.c     ****     blockData[14] = (uint8_t)(sum);
 472:BSP/NFC.c     ****     blockData[15] = (uint8_t)(sum >> 8);
 473:BSP/NFC.c     **** 
 474:BSP/NFC.c     ****     /* 认证 + 写入 */
 475:BSP/NFC.c     ****     status = RC522_AuthState(RC522_PICC_AUTHENT1A, 3, (uint8_t*)s_defaultKey, uid);
 476:BSP/NFC.c     ****     if (status != RC522_OK) { NFC_Recover(); return "ERR:AUTH\n"; }
 477:BSP/NFC.c     **** 
 478:BSP/NFC.c     ****     status = RC522_WriteBlock(0, 1, blockData);
 479:BSP/NFC.c     ****     if (status != RC522_OK) { NFC_Recover(); return "ERR:WRITE_B1\n"; }
 480:BSP/NFC.c     **** 
 481:BSP/NFC.c     ****     /* 写完后 Halt 卡, 使卡回休眠态 */
 482:BSP/NFC.c     ****     RC522_Halt();
 483:BSP/NFC.c     **** 
 484:BSP/NFC.c     ****     /* 缓存 UID */
 485:BSP/NFC.c     ****     memcpy(s_lastUID, uid, 4);
 486:BSP/NFC.c     ****     UIDToStr(uid, s_lastUIDStr);
 487:BSP/NFC.c     **** 
 488:BSP/NFC.c     ****     return "OK\n";
 489:BSP/NFC.c     **** }
 490:BSP/NFC.c     **** 
 491:BSP/NFC.c     **** /**
 492:BSP/NFC.c     ****  * @brief  读卡验证并返回数据
 493:BSP/NFC.c     ****  */
 494:BSP/NFC.c     **** static const char *NFC_CmdRead(char *respBuf, uint16_t bufSize)
 495:BSP/NFC.c     **** {
 496:BSP/NFC.c     ****     uint8_t uid[4];
 497:BSP/NFC.c     ****     uint8_t blockData[16];
 498:BSP/NFC.c     ****     char    status;
 499:BSP/NFC.c     **** 
 500:BSP/NFC.c     ****     RC522_Halt();
 501:BSP/NFC.c     ****     osDelay(2);
 502:BSP/NFC.c     ****     status = RC522_ScanCard(uid);
 503:BSP/NFC.c     ****     if (status != RC522_OK) return "ERR:NOCARD\n";
 504:BSP/NFC.c     **** 
 505:BSP/NFC.c     ****     status = RC522_AuthState(RC522_PICC_AUTHENT1A, 3, (uint8_t*)s_defaultKey, uid);
 506:BSP/NFC.c     ****     if (status != RC522_OK) return "ERR:AUTH\n";
 507:BSP/NFC.c     **** 
 508:BSP/NFC.c     ****     status = RC522_ReadBlock(0, 1, blockData);
 509:BSP/NFC.c     ****     if (status != RC522_OK) return "ERR:WRITE_B1\n";
 510:BSP/NFC.c     **** 
 511:BSP/NFC.c     ****     /* 缓存 UID */
 512:BSP/NFC.c     ****     memcpy(s_lastUID, uid, 4);
 513:BSP/NFC.c     ****     UIDToStr(uid, s_lastUIDStr);
ARM GAS  C:\Users\24120\AppData\Local\Temp\ccaaYZuv.s 			page 15


 514:BSP/NFC.c     **** 
 515:BSP/NFC.c     ****     uint32_t sid = (uint32_t)blockData[4]       | ((uint32_t)blockData[5] << 8) |
 516:BSP/NFC.c     ****                      ((uint32_t)blockData[6] << 16) | ((uint32_t)blockData[7] << 24);
 517:BSP/NFC.c     **** 
 518:BSP/NFC.c     ****     snprintf(respBuf, bufSize,
 519:BSP/NFC.c     ****              "UID:%s\nSID:%lu\nTYPE:%d\n",
 520:BSP/NFC.c     ****              s_lastUIDStr, (unsigned long)sid, blockData[12]);
 521:BSP/NFC.c     ****     return respBuf;
 522:BSP/NFC.c     **** }
 523:BSP/NFC.c     **** 
