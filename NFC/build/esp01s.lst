1250:BSP/esp01s.c  ****  * @param  pTime   ж—¶й—ҙз»“жһ„жҢҮй’Ҳ
1251:BSP/esp01s.c  ****  * @param  format  ж јејҸзұ»еһӢ: DT_DATE/DT_TIME/DT_ALL
1252:BSP/esp01s.c  ****  * @param  pBuf    иҫ“еҮәзј“еҶІеҢә
1253:BSP/esp01s.c  ****  * @param  bufLen  зј“еҶІеҢәй•ҝеәҰ
1254:BSP/esp01s.c  ****  * @note   иҫ“еҮәзӨәдҫӢ:
1255:BSP/esp01s.c  ****  *         DT_DATE: "2026-04-12"
1256:BSP/esp01s.c  ****  *         DT_TIME: "14:30:45"
1257:BSP/esp01s.c  ****  *         DT_ALL:  "2026-04-12 14:30:45"
1258:BSP/esp01s.c  ****  */
1259:BSP/esp01s.c  **** static void FormatDateTime(const ESP01S_NtpTime_t *pTime, DT_Format_t format, char *pBuf, uint16_t 
1260:BSP/esp01s.c  **** {
1261:BSP/esp01s.c  ****     switch (format)
1262:BSP/esp01s.c  ****     {
1263:BSP/esp01s.c  ****     case DT_DATE:
1264:BSP/esp01s.c  ****         snprintf(pBuf, bufLen, "%04d-%02d-%02d",
1265:BSP/esp01s.c  ****                  pTime->year, pTime->month, pTime->day);
1266:BSP/esp01s.c  ****         break;
1267:BSP/esp01s.c  ****     case DT_TIME:
1268:BSP/esp01s.c  ****         snprintf(pBuf, bufLen, "%02d:%02d:%02d",
1269:BSP/esp01s.c  ****                  pTime->hour, pTime->minute, pTime->second);
1270:BSP/esp01s.c  ****         break;
1271:BSP/esp01s.c  ****     case DT_ALL:
ARM GAS  C:\Users\24120\AppData\Local\Temp\ccEY3EY5.s 			page 29


1272:BSP/esp01s.c  ****     default:
1273:BSP/esp01s.c  ****         snprintf(pBuf, bufLen, "%04d-%02d-%02d %02d:%02d:%02d",
1274:BSP/esp01s.c  ****                  pTime->year, pTime->month, pTime->day,
1275:BSP/esp01s.c  ****                  pTime->hour, pTime->minute, pTime->second);
1276:BSP/esp01s.c  ****         break;
1277:BSP/esp01s.c  ****     }
1278:BSP/esp01s.c  **** }
