  99:BSP/rc522_platform_stm32.c **** 
 100:BSP/rc522_platform_stm32.c ****         /* SCK ن¸ٹهچ‡و²? -> ن»ژوœ؛é‡‡و · MOSI */
 101:BSP/rc522_platform_stm32.c ****         HAL_GPIO_WritePin(NFC_SCK_GPIO_Port, NFC_SCK_Pin, GPIO_PIN_SET);
 102:BSP/rc522_platform_stm32.c ****         delay_us(1);
 103:BSP/rc522_platform_stm32.c **** 
