 172:BSP/rc522.c   **** 
 173:BSP/rc522.c   ****     /* ж №жҚ®е‘Ҫд»Өзұ»еһӢйҖүжӢ©дёӯж–ӯдҪҝиғҪе’Ңзӯүеҫ…ж Үеҝ— */
ARM GAS  C:\Users\24120\AppData\Local\Temp\cc8JRStv.s 			page 11


 174:BSP/rc522.c   ****     switch (Command) {
 175:BSP/rc522.c   ****         case RC522_CMD_AUTHENT:
 176:BSP/rc522.c   ****             irqEn   = 0x12;
 177:BSP/rc522.c   ****             waitFor = 0x10;
 178:BSP/rc522.c   ****             break;
 179:BSP/rc522.c   **** 
 180:BSP/rc522.c   ****         case RC522_CMD_TRANSCEIVE:
 181:BSP/rc522.c   ****             irqEn   = 0x77;
 182:BSP/rc522.c   ****             waitFor = 0x30;
 183:BSP/rc522.c   ****             break;
 184:BSP/rc522.c   **** 
 185:BSP/rc522.c   ****         default:
 186:BSP/rc522.c   ****             break;
 187:BSP/rc522.c   ****     }
 188:BSP/rc522.c   **** 
 189:BSP/rc522.c   ****     /* й…ҚзҪ®дёӯж–ӯе’Ң FIFO */
 190:BSP/rc522.c   ****     rc522_write_reg(RC522_REG_COMIEN, irqEn | 0x80);  /* дҪҝиғҪзӣёе…ідёӯж–ӯ */
