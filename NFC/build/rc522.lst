 192:BSP/rc522.c   ****     rc522_write_reg(RC522_REG_COMMAND, RC522_CMD_IDLE);/* еҸ–ж¶ҲеҪ“еүҚе‘Ҫд»Ө */
 193:BSP/rc522.c   ****     rc522_set_bit_mask(RC522_REG_FIFOLEVEL, 0x80);     /* жё…з©ә FIFO */
 194:BSP/rc522.c   **** 
 195:BSP/rc522.c   ****     /* е°ҶиҰҒеҸ‘йҖҒзҡ„ж•°жҚ®еҶҷе…Ҙ FIFO */
 196:BSP/rc522.c   ****     for (i = 0; i < InLenByte; i++) {
 197:BSP/rc522.c   ****         rc522_write_reg(RC522_REG_FIFODATA, pInData[i]);
 198:BSP/rc522.c   ****     }
 199:BSP/rc522.c   **** 
 200:BSP/rc522.c   ****     /* еҗҜеҠЁе‘Ҫд»Ө */
 201:BSP/rc522.c   ****     rc522_write_reg(RC522_REG_COMMAND, Command);
 202:BSP/rc522.c   **** 
 203:BSP/rc522.c   ****     /* еҰӮжһңжҳҜж”¶еҸ‘е‘Ҫд»ӨпјҢеңЁеҸ‘йҖҒжңҖеҗҺдёҖдёӘеӯ—иҠӮеҗҺиҮӘеҠЁејҖеҗҜжҺҘж”¶ */
 204:BSP/rc522.c   ****     if (Command == RC522_CMD_TRANSCEIVE) {
 205:BSP/rc522.c   ****         rc522_set_bit_mask(RC522_REG_BITFRAMING, 0x80);
 206:BSP/rc522.c   ****     }
 207:BSP/rc522.c   **** 
 208:BSP/rc522.c   ****     /* зӯүеҫ…е‘Ҫд»Өе®ҢжҲҗжҲ–и¶…ж—¶ */
 209:BSP/rc522.c   ****     i = RC522_COMM_TIMEOUT;
 210:BSP/rc522.c   ****     do {
 211:BSP/rc522.c   ****         n = rc522_read_reg(RC522_REG_COMIRQ);
 212:BSP/rc522.c   ****         i--;
 213:BSP/rc522.c   ****     } while ((i != 0) && !(n & 0x01) && !(n & waitFor));
 214:BSP/rc522.c   **** 
 215:BSP/rc522.c   ****     rc522_clear_bit_mask(RC522_REG_BITFRAMING, 0x80); /* жё…йҷӨдҪҚеё§и°ғж•ҙ */
 216:BSP/rc522.c   **** 
 217:BSP/rc522.c   ****     if (i != 0) {
 218:BSP/rc522.c   ****         /* жЈҖжҹҘй”ҷиҜҜеҜ„еӯҳеҷЁ (TimerErr | CRCErr | ParityErr | ProtocolErr) */
 219:BSP/rc522.c   ****         if (!(rc522_read_reg(RC522_REG_ERROR) & 0x1B)) {
 220:BSP/rc522.c   ****             status = RC522_OK;
 221:BSP/rc522.c   **** 
 222:BSP/rc522.c   ****             /* жЈҖжҹҘжҳҜеҗҰж”¶еҲ° Set1 (иЎЁзӨәж— ж Үзӯҫе“Қеә”) */
 223:BSP/rc522.c   ****             if (n & irqEn & 0x01) {
 224:BSP/rc522.c   ****                 status = RC522_ERR_NO_TAG;
 225:BSP/rc522.c   ****             }
 226:BSP/rc522.c   **** 
 227:BSP/rc522.c   ****             /* ж”¶еҸ‘е‘Ҫд»ӨйңҖиҰҒиҜ»еҸ–иҝ”еӣһж•°жҚ® */
 228:BSP/rc522.c   ****             if (Command == RC522_CMD_TRANSCEIVE) {
 229:BSP/rc522.c   ****                 n = rc522_read_reg(RC522_REG_FIFOLEVEL);
 230:BSP/rc522.c   ****                 lastBits = rc522_read_reg(RC522_REG_CONTROL) & 0x07;
ARM GAS  C:\Users\24120\AppData\Local\Temp\cc8JRStv.s 			page 12


 231:BSP/rc522.c   **** 
 232:BSP/rc522.c   ****                 /* и®Ўз®—жҺҘж”¶еҲ°зҡ„дҪҚй•ҝеәҰ */
 233:BSP/rc522.c   ****                 if (lastBits) {
 234:BSP/rc522.c   ****                     *pOutLenBit = (n - 1) * 8 + lastBits;
 235:BSP/rc522.c   ****                 } else {
 236:BSP/rc522.c   ****                     *pOutLenBit = n * 8;
 237:BSP/rc522.c   ****                 }
 238:BSP/rc522.c   **** 
 239:BSP/rc522.c   ****                 /* еӨ„зҗҶ FIFO з©әзҡ„жғ…еҶө */
 240:BSP/rc522.c   ****                 if (n == 0) {
 241:BSP/rc522.c   ****                     n = 1;
 242:BSP/rc522.c   ****                 }
 243:BSP/rc522.c   ****                 if (n > RC522_INTERNAL_BUF_LEN) {
 244:BSP/rc522.c   ****                     n = RC522_INTERNAL_BUF_LEN;
 245:BSP/rc522.c   ****                 }
 246:BSP/rc522.c   **** 
 247:BSP/rc522.c   ****                 /* д»Һ FIFO иҜ»еҸ–ж•°жҚ® */
 248:BSP/rc522.c   ****                 for (i = 0; i < n; i++) {
 249:BSP/rc522.c   ****                     pOutData[i] = rc522_read_reg(RC522_REG_FIFODATA);
 250:BSP/rc522.c   ****                 }
 251:BSP/rc522.c   ****             }
 252:BSP/rc522.c   ****         } else {
 253:BSP/rc522.c   ****             status = RC522_ERR;
 254:BSP/rc522.c   ****         }
 255:BSP/rc522.c   ****     }
 256:BSP/rc522.c   **** 
 257:BSP/rc522.c   ****     /* еҒңжӯўе®ҡж—¶еҷЁе№¶еҸ–ж¶Ҳе‘Ҫд»Ө */
 258:BSP/rc522.c   ****     rc522_set_bit_mask(RC522_REG_CONTROL, 0x80);
 259:BSP/rc522.c   ****     rc522_write_reg(RC522_REG_COMMAND, RC522_CMD_IDLE);
 260:BSP/rc522.c   **** 
 261:BSP/rc522.c   ****     /* иҝһз»ӯйҖҡдҝЎеӨұиҙҘи®Ўж•°: жҲҗеҠҹжё…йӣ¶, и¶…ж—¶/й”ҷиҜҜзҙҜи®Ў, и¶…иҝҮйҳҲеҖјеҲҷзЎ¬д»¶еӨҚдҪҚ */
 262:BSP/rc522.c   ****     if (status == RC522_OK) {
 263:BSP/rc522.c   ****         s_commFailCount = 0;
 264:BSP/rc522.c   ****     } else {
 265:BSP/rc522.c   ****         s_commFailCount++;
 266:BSP/rc522.c   ****         if (s_commFailCount >= RC522_COMM_FAIL_THRESHOLD) {
