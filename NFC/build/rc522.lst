 157:BSP/rc522.c   ****  * @param pOutData   жҺҘж”¶ж•°жҚ®зј“еҶІеҢә
 158:BSP/rc522.c   ****  * @param pOutLenBit иҫ“еҮәеҸӮж•°пјҢжҺҘж”¶ж•°жҚ®зҡ„дҪҚй•ҝеәҰ
 159:BSP/rc522.c   ****  * @return RC522_OK жҲҗеҠҹпјҢRC522_ERR еӨұиҙҘпјҢRC522_ERR_NO_TAG ж— еҚЎе“Қеә”
 160:BSP/rc522.c   ****  */
 161:BSP/rc522.c   **** static char rc522_communicate(uint8_t Command,
 162:BSP/rc522.c   ****                               const uint8_t *pInData,
 163:BSP/rc522.c   ****                               uint8_t InLenByte,
 164:BSP/rc522.c   ****                               uint8_t *pOutData,
 165:BSP/rc522.c   ****                               uint32_t *pOutLenBit)
 166:BSP/rc522.c   **** {
 167:BSP/rc522.c   ****     char status = RC522_ERR;
