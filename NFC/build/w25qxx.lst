 249:BSP/w25qxx.c  ****     uint8_t * W25QXX_BUF;
 250:BSP/w25qxx.c  ****     W25QXX_BUF=W25QXX_BUFFER;
 251:BSP/w25qxx.c  ****     secpos=WriteAddr/SECTOR_SIZE;//ЩШЧјЕижЗ
 252:BSP/w25qxx.c  ****     secoff=WriteAddr%SECTOR_SIZE;//дкЩШЧјФкЕФЦЋвЦ
 253:BSP/w25qxx.c  ****     secremain=SECTOR_SIZE-secoff;//ЩШЧјЪЃгрПеМфДѓаЁ
 254:BSP/w25qxx.c  **** // 	printf("ad:%X,nb:%X\r\n",WriteAddr,NumByteToWrite);//ВтЪдгУ
 255:BSP/w25qxx.c  ****     if(NumByteToWrite<=secremain)secremain=NumByteToWrite;//ВЛДѓгк4096ИізжНк
 256:BSP/w25qxx.c  ****     while(1)
 257:BSP/w25qxx.c  ****     {
 258:BSP/w25qxx.c  ****         W25QXX_Read(W25QXX_BUF,secpos*SECTOR_SIZE,SECTOR_SIZE);//ЖСГіећИіЩШЧјЕФФкШн
 259:BSP/w25qxx.c  ****         for(i=0; i<secremain; i++) //аЃбщЪ§Он
 260:BSP/w25qxx.c  ****         {
 261:BSP/w25qxx.c  ****             if(W25QXX_BUF[secoff+i]!=0XFF)break;//ашвЊВСГ§
 262:BSP/w25qxx.c  ****         }
 263:BSP/w25qxx.c  ****         if(i<secremain)//ашвЊВСГ§
 264:BSP/w25qxx.c  ****         {
 265:BSP/w25qxx.c  ****             W25QXX_Erase_Sector(secpos);//ВСГ§етИіЩШЧј
 266:BSP/w25qxx.c  ****             for(i=0; i<secremain; i++)	 //ИДжЦ
 267:BSP/w25qxx.c  ****             {
 268:BSP/w25qxx.c  ****                 W25QXX_BUF[i+secoff]=pBuffer[i];
 269:BSP/w25qxx.c  ****             }
 270:BSP/w25qxx.c  ****             W25QXX_Write_NoCheck(W25QXX_BUF,secpos*SECTOR_SIZE,SECTOR_SIZE);//аДШыећИіЩШЧј
 271:BSP/w25qxx.c  ****         }
 272:BSP/w25qxx.c  ****         else W25QXX_Write_NoCheck(pBuffer,WriteAddr,secremain); //аДвбО­ВСГ§СЫЕФ,жБНгаДШыЩШЧјЪЃгрЧј
 273:BSP/w25qxx.c  ****         if(NumByteToWrite==secremain)break;//аДШыНсЪјСЫ
 274:BSP/w25qxx.c  ****         else//аДШыЮДНсЪј
 275:BSP/w25qxx.c  ****         {
 276:BSP/w25qxx.c  ****             secpos++;//ЩШЧјЕижЗді1
 277:BSP/w25qxx.c  ****             secoff=0;//ЦЋвЦЮЛжУЮЊ0
 278:BSP/w25qxx.c  **** 
 279:BSP/w25qxx.c  ****             pBuffer+=secremain;  //жИеыЦЋвЦ
 280:BSP/w25qxx.c  ****             WriteAddr+=secremain;//аДЕижЗЦЋвЦ
 281:BSP/w25qxx.c  ****             NumByteToWrite-=secremain;				//зжНкЪ§ЕнМѕ
 282:BSP/w25qxx.c  ****             if(NumByteToWrite>SECTOR_SIZE)secremain=SECTOR_SIZE;	//ЯТвЛИіЩШЧјЛЙЪЧаДВЛЭъ
 283:BSP/w25qxx.c  ****             else secremain=NumByteToWrite;			//ЯТвЛИіЩШЧјПЩвдаДЭъСЫ
 284:BSP/w25qxx.c  ****         }
 285:BSP/w25qxx.c  ****     };
 286:BSP/w25qxx.c  **** }
