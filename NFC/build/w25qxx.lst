 216:BSP/w25qxx.c  **** void W25QXX_Write_NoCheck(uint8_t* pBuffer,uint32_t WriteAddr,uint32_t NumByteToWrite)
 217:BSP/w25qxx.c  **** {
 218:BSP/w25qxx.c  ****     uint16_t pageremain;
 219:BSP/w25qxx.c  ****     pageremain=256-WriteAddr%256; //ЕЅвГЪЃгрЕФзжНкЪ§
 220:BSP/w25qxx.c  ****     if(NumByteToWrite<=pageremain)pageremain=NumByteToWrite;//ВЛДѓгк256ИізжНк
 221:BSP/w25qxx.c  ****     while(1)
 222:BSP/w25qxx.c  ****     {
 223:BSP/w25qxx.c  ****         W25QXX_Write_Page(pBuffer,WriteAddr,pageremain);
 224:BSP/w25qxx.c  ****         if(NumByteToWrite==pageremain)break;//аДШыНсЪјСЫ
 225:BSP/w25qxx.c  ****         else //NumByteToWrite>pageremain
 226:BSP/w25qxx.c  ****         {
 227:BSP/w25qxx.c  ****             pBuffer+=pageremain;
 228:BSP/w25qxx.c  ****             WriteAddr+=pageremain;
 229:BSP/w25qxx.c  **** 
 230:BSP/w25qxx.c  ****             NumByteToWrite-=pageremain;			  //МѕШЅвбО­аДШыСЫЕФзжНкЪ§
