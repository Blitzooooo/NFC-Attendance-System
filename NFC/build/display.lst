  70:BSP/display.c **** /* ====== RTC 时间戳工具 ====== */
  71:BSP/display.c **** 
  72:BSP/display.c **** /** 每月天数 (非闰年) */
  73:BSP/display.c **** static const uint8_t s_daysInMonth[12] = {31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31};
  74:BSP/display.c **** 
  75:BSP/display.c **** /**
  76:BSP/display.c ****  * @brief  将 BSP_RTC_DateTime_t 转为距 2024-01-01 00:00:00 的秒数
  77:BSP/display.c ****  * @note   支持跨天时长计算, uint32_t 可覆盖 ~136 年
  78:BSP/display.c ****  */
  79:BSP/display.c **** uint32_t DISP_DateTimeToSeconds(const BSP_RTC_DateTime_t *dt)
  80:BSP/display.c **** {
  81:BSP/display.c ****     uint32_t days = 0;
  82:BSP/display.c ****     uint16_t y;
  83:BSP/display.c **** 
  84:BSP/display.c ****     /* 累加整年天数 */
  85:BSP/display.c ****     for (y = 2024; y < dt->year; y++) {
  86:BSP/display.c ****         days += BSP_RTC_IsLeapYear(y) ? 366U : 365U;
  87:BSP/display.c ****     }
ARM GAS  C:\Users\24120\AppData\Local\Temp\cciaFKJB.s 			page 3


  88:BSP/display.c **** 
  89:BSP/display.c ****     /* 累加当年整月天数 */
  90:BSP/display.c ****     for (uint8_t m = 1; m < dt->month; m++) {
  91:BSP/display.c ****         days += s_daysInMonth[m - 1];
  92:BSP/display.c ****         if (m == 2 && BSP_RTC_IsLeapYear(dt->year)) days++;
  93:BSP/display.c ****     }
  94:BSP/display.c **** 
  95:BSP/display.c ****     /* 累加当月天数 */
  96:BSP/display.c ****     days += (uint32_t)(dt->day - 1);
  97:BSP/display.c **** 
  98:BSP/display.c ****     return days * 86400U + (uint32_t)dt->hour * 3600U
  99:BSP/display.c ****                          + (uint32_t)dt->minute * 60U
 100:BSP/display.c ****                          + (uint32_t)dt->second;
 101:BSP/display.c **** }
