 253:BSP/display.c ****     osDelay(2000);  /* LOGO 显示 2s */
 254:BSP/display.c **** 
 255:BSP/display.c ****     drawInfoPage();
 256:BSP/display.c ****     GUI_Update();
 257:BSP/display.c ****     osDelay(1000);
 258:BSP/display.c **** }
