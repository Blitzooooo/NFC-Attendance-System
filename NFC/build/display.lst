 202:BSP/display.c ****     memset(&s_cardInfo, 0, sizeof(s_cardInfo));
 203:BSP/display.c ****     memset(&s_cardBitmap, 0, sizeof(s_cardBitmap));
 204:BSP/display.c ****     s_state = DISP_STATE_CLOCK;
 205:BSP/display.c ****     s_adminCfg.deviceId = 1;
 206:BSP/display.c ****     s_adminCfg.attendMode = 2;  /* 默认出入口模式 */
 207:BSP/display.c ****     s_lastFrameTick = 0;  /* 重置看门狗时间戳 */
 208:BSP/display.c **** }
 209:BSP/display.c **** 
 210:BSP/display.c **** /**
 211:BSP/display.c ****  * @brief  应用 I2C 时钟配置 (覆盖 CubeMX 默认值)
 212:BSP/display.c ****  * @note   在 MX_I2C1_Init() 之后调用, 确保 I2C 频率与 DISP_I2C_TARGET_HZ 一致
 213:BSP/display.c ****  */
 214:BSP/display.c **** void DISP_ApplyI2CConfig(void)
 215:BSP/display.c **** {
 216:BSP/display.c ****     if (hi2c1.Init.ClockSpeed != DISP_I2C_TARGET_HZ) {
 217:BSP/display.c ****         hi2c1.Init.ClockSpeed = DISP_I2C_TARGET_HZ;
 218:BSP/display.c ****         HAL_I2C_DeInit(&hi2c1);
 219:BSP/display.c ****         HAL_I2C_Init(&hi2c1);
 220:BSP/display.c ****     }
 221:BSP/display.c **** }
 222:BSP/display.c **** 
 223:BSP/display.c **** DispState_t DISP_GetState(void)
 224:BSP/display.c **** {
 225:BSP/display.c ****     return s_state;
 226:BSP/display.c **** }
 227:BSP/display.c **** 
 228:BSP/display.c **** void DISP_SetState(DispState_t state)
 229:BSP/display.c **** {
 230:BSP/display.c ****     /* 从管理员设置退出且非 K6 保存 → 恢复旧配置 */
 231:BSP/display.c ****     if (s_state == DISP_STATE_ADMIN_SET && state != DISP_STATE_ADMIN_SET) {
 232:BSP/display.c ****         s_adminCfg = s_adminSet.backup;
 233:BSP/display.c ****     }
 234:BSP/display.c ****     s_state = state;
 235:BSP/display.c ****     /* 进入时间设置时复制当前 RTC 值 */
 236:BSP/display.c ****     if (state == DISP_STATE_TIME_SET) {
 237:BSP/display.c ****         BSP_RTC_GetDateTime(&s_timeSet.dt);
 238:BSP/display.c ****         s_timeSet.cursor = 0;
 239:BSP/display.c ****         s_timeSet.enterTick = osKernelGetTickCount();
 240:BSP/display.c ****     }
 241:BSP/display.c ****     /* 进入管理员设置时记录时间 */
 242:BSP/display.c ****     if (state == DISP_STATE_ADMIN_SET) {
 243:BSP/display.c ****         s_adminSet.cursor = 0;
 244:BSP/display.c ****         s_adminSet.enterTick = osKernelGetTickCount();
 245:BSP/display.c ****         s_adminSet.backup = s_adminCfg;  /* 保存副本, 取消时恢复 */
 246:BSP/display.c ****     }
 247:BSP/display.c **** }
 248:BSP/display.c **** 
 249:BSP/display.c **** void DISP_RunStartup(void)
 250:BSP/display.c **** {
