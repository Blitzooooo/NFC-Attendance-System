 154:BSP/display.c **** /* ====== 公开 API: 初始化 & 状态管理 ====== */
 155:BSP/display.c **** 
 156:BSP/display.c **** /* ====== OLED 防卡顿看门狗 ====== */
 157:BSP/display.c **** 
 158:BSP/display.c **** /** 超过此时间(ms)无刷新视为卡顿, 触发 OLED 硬件复位 */
 159:BSP/display.c **** #define DISP_STUCK_TIMEOUT_MS  3000
 160:BSP/display.c **** 
 161:BSP/display.c **** /** 最后一次刷新时刻 (FreeRTOS tick) */
 162:BSP/display.c **** static uint32_t s_lastFrameTick = 0;
 163:BSP/display.c **** 
 164:BSP/display.c **** /**
 165:BSP/display.c ****  * @brief  喂狗: 记录当前帧刷新时刻
 166:BSP/display.c ****  * @note   每帧渲染完成后调用 (guiTask 上下文)
 167:BSP/display.c ****  */
 168:BSP/display.c **** void DISP_FeedWatchdog(void)
 169:BSP/display.c **** {
 170:BSP/display.c ****     s_lastFrameTick = osKernelGetTickCount();
 171:BSP/display.c **** }
 172:BSP/display.c **** 
 173:BSP/display.c **** /**
 174:BSP/display.c ****  * @brief  检测 OLED 是否卡顿
 175:BSP/display.c ****  * @return 1=卡顿 (超过 DISP_STUCK_TIMEOUT_MS 未刷新), 0=正常
 176:BSP/display.c ****  */
 177:BSP/display.c **** uint8_t DISP_CheckStuck(void)
 178:BSP/display.c **** {
 179:BSP/display.c ****     if (s_lastFrameTick == 0) return 0;  /* 尚未完成首帧渲染 */
 180:BSP/display.c ****     uint32_t elapsed = osKernelGetTickCount() - s_lastFrameTick;
 181:BSP/display.c ****     return (elapsed >= DISP_STUCK_TIMEOUT_MS) ? 1 : 0;
 182:BSP/display.c **** }
 183:BSP/display.c **** 
 184:BSP/display.c **** /**
 185:BSP/display.c ****  * @brief  重置 OLED: 硬件复位 + 重新初始化芯片和 GUI + 清屏刷新
 186:BSP/display.c ****  * @note   在检测到卡顿后调用, 恢复 OLED 正常显示
 187:BSP/display.c ****  */
 188:BSP/display.c **** void DISP_ResetOLED(void)
 189:BSP/display.c **** {
 190:BSP/display.c ****     SSD1306_init();       /* 重新初始化 OLED 芯片 (含自检+配置) */
 191:BSP/display.c ****     GUI_Init();           /* 重新初始化 GUI 上下文 */
 192:BSP/display.c ****     GUI_Clear();          /* 清空帧缓冲 */
 193:BSP/display.c ****     GUI_SetColor(GUI_COLOR_WHITE);
 194:BSP/display.c ****     GUI_Update();         /* 立即刷新一帧黑屏, 清除可能的花屏 */
 195:BSP/display.c ****     DISP_FeedWatchdog();  /* 重置看门狗时间戳 */
 196:BSP/display.c **** }
 197:BSP/display.c **** 
