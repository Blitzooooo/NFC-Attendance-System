{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "make",
            "args": ["-j4"],
            "options": {
                "cwd": "${workspaceFolder}/NFC"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": {
                "owner": "cpp",
                "fileLocation": ["relative", "${workspaceFolder}/NFC"],
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            }
        },
        {
            "label": "Flash",
            "type": "shell",
            "command": "${workspaceFolder}\\tools\\openocd\\0.12.0-7.1\\.content\\bin\\openocd.exe",
            "args": [
                "-s", "${workspaceFolder}\\tools\\openocd\\0.12.0-7.1\\.content\\openocd\\scripts",
                "-f", "interface/cmsis-dap.cfg",
                "-f", "target/stm32f4x.cfg",
                "-c", "program NFC/build/NFCAttend.elf verify reset exit"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": ["Build"],
            "problemMatcher": []
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "make",
            "args": ["clean"],
            "options": {
                "cwd": "${workspaceFolder}/NFC"
            },
            "problemMatcher": []
        }
    ]
}
